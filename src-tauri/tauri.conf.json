{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "scrcpy Launcher",
  "version": "0.1.5",
  "identifier": "dev.scrcpy-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "scrcpy Launcher",
        "width": 1120,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://play.google.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "license": "LICENSE",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
